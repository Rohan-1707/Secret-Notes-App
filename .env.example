# =============================================
# SECRET NOTES APP - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to GitHub!
# =============================================

# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/secretnotes?retryWrites=true&w=majority

# JWT Secret Key (use a long random string, at least 32 characters)
# Generate one: https://www.lastpass.com/features/password-generator
JWT_SECRET=replace_this_with_a_very_long_random_secret_key

# Email Configuration (for sending OTPs / notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Server Port
PORT=8000

# App Environment (development | production)
NODE_ENV=development
